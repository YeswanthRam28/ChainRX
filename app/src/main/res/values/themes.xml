<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.ChainRX" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_teal</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/primary_light</item>
        <item name="colorOnSecondary">@color/text_dark</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/bg_soft_blue</item>
        <item name="android:windowLightStatusBar">true</item>
        
        <item name="android:windowBackground">@color/bg_soft_blue</item>
    </style>

    <style name="CardView.ChainRX" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/bg_white</item>
        <item name="android:stateListAnimator" tools:targetApi="l">@null</item>
    </style>
</resources>